#!/usr/bin/env

DOCKER_CLIENT_TIMEOUT=120
COMPOSE_HTTP_TIMEOUT=120
# config for dev, we start prometheus and node services
COMPOSE_PATH_SEPARATOR=:
COMPOSE_FILE=docker-compose.yml:docker-compose.node.yml
COMPOSE_PROJECT_NAME=monitoring
# Restart policy, no for local development
RESTART_POLICY=no

# InfluxDB
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=admin123
INFLUXDB_DB=db0

# by default those ports are exposed on localhost only, on standard ports,
# but you can change them
#ES_API_EXPOSE=
#ES_NODE_COMMUNICATION_EXPOSE=
#ES_EXPORTER_EXPOSE=
#BLACKBOX_EXPORTER_EXPOSE=
#INFLUXDB_EXPOSE=
#PROMETHEUS_EXPOSE=

# Filebeat
ELASTICSEARCH_HOSTS=http://elasticsearch:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
KIBANA_HOST=http://kibana:5601

# Alertmanager
SLACK_WEBHOOK_URL_INFRASTRUCTURE_ALERTS_0=http://localhost

# Sentry DSN for exporting sampled traces/events
SENTRY_URL=https://sentry.io
SENTRY_ORG_SLUG=local
SENTRY_AUTH_TOKEN=localtoken

# Probabilistic sampling percentage (integer 0-100). Default 1% if unset.
OTEL_PROBABILISTIC_SAMPLING_PERCENTAGE=1

# Central OTEL Collector host (used by per-node Alloy to forward OTLP)
# Default is the internal docker service name and port; if you map host ports
# change this to the host/IP and exposed port (e.g. 192.0.2.10:14317).
OTELCOL_HOST=otelcol:14317

# Host ports for central otelcol (defaults chosen to avoid common 4317/4318 conflicts)
OTELCOL_OTLP_GRPC_EXPOSE=127.0.0.1:14317
OTELCOL_OTLP_HTTP_EXPOSE=127.0.0.1:14318